{
	"name": "@repo/vitest-config",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./base": {
			"import": {
				"types": "./dist/base.d.mts",
				"default": "./dist/base.mjs"
			},
			"require": {
				"types": "./dist/base.d.cts",
				"default": "./dist/base.cjs"
			}
		},
		"./nest": {
			"import": {
				"types": "./dist/nest.d.mts",
				"default": "./dist/nest.mjs"
			},
			"require": {
				"types": "./dist/nest.d.cts",
				"default": "./dist/nest.cjs"
			}
		}
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"tsdown": "catalog:tsdown",
		"typescript": "catalog:typescript",
		"vitest": "catalog:vitest"
	},
	"scripts": {
		"build": "tsdown"
	}
}
