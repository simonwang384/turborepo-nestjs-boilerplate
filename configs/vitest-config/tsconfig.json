{
	"extends": "@testify/typescript-config/base.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"allowJs": true,
		"esModuleInterop": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"outDir": "dist",
		"rootDir": "src"
	},
	"include": ["src"],
	"exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
