{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!**/dist", "!**/migrations", "!**/*.d.ts", "!**/routeTree.gen.ts"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 110,
		"formatWithErrors": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"useAwait": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"jsxQuoteStyle": "single"
		},
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [":PACKAGE:", ":BLANK_LINE:", ":NODE:"]
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": [
				"**/*.service.ts",
				"**/*.controller.ts",
				"**/*.module.ts",
				"**/*.repository.ts",
				"**/*.entity.ts",
				"**/*.filter.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"useImportType": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.spec.ts", "**/*.test.ts", "**/file-route-utils.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
