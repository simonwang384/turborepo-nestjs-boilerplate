{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"compilerOptions": {
		"deleteOutDir": true,
		"builder": {
			"type": "swc",
			"options": {
				"swcrcPath": "node_modules/@repo/swc-config/.swcrc"
			}
		},
		"typeCheck": true
	}
}
